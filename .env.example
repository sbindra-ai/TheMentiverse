# Application
# Match the port Next prints (3000 by default; 3001 if 3000 is already in use).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk authentication (required for sign-in / sign-up / Google OAuth)
# Paste REAL keys from https://dashboard.clerk.com — leave blank to run the site without auth.
# Fake values like pk_test_paste_here will crash with "Publishable key not valid."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# PostgreSQL / Neon — not required for auth.
DATABASE_URL=postgresql://mentiverse:mentiverse@localhost:5432/mentiverse

# Future integrations
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
